# Stellaris Companion - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# Which LLM provider to use:
#   google_gemini     - Google Gemini (cloud, default)
#   openai            - OpenAI GPT (cloud)
#   anthropic         - Anthropic Claude (cloud)
#   openai_compatible - OpenAI-compatible API (local: LM Studio, vLLM, LocalAI)
#   ollama            - Ollama native API (local)
LLM_PROVIDER=google_gemini

# Universal API key (used if provider-specific key not set)
# LLM_API_KEY=your-api-key-here

# Model to use (optional, uses provider default if not set)
# Examples:
#   Google Gemini: gemini-2.0-flash, gemini-1.5-pro
#   OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
#   Anthropic: claude-sonnet-4-20250514, claude-3-opus-20240229
#   Ollama: llama3.2, mistral, codellama
# LLM_MODEL=gemini-2.0-flash

# Base URL for local providers (required for openai_compatible and ollama)
# LLM_BASE_URL=http://localhost:11434

# Generation parameters (optional)
# LLM_TEMPERATURE=1.0
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=120

# =============================================================================
# PROVIDER-SPECIFIC API KEYS (alternative to LLM_API_KEY)
# =============================================================================

# Google Gemini API key (for google_gemini provider)
# Get one from: https://aistudio.google.com/
GOOGLE_API_KEY=your-gemini-api-key-here

# OpenAI API key (for openai provider)
# Get one from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API key (for anthropic provider)
# Get one from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# LOCAL MODEL CONFIGURATION
# =============================================================================

# Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible server base URL (for LM Studio, vLLM, LocalAI, etc.)
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000

# =============================================================================
# ELECTRON APP
# =============================================================================

# API token for Electron <-> Python backend communication
# Generate a random string, e.g.: openssl rand -hex 32
STELLARIS_API_TOKEN=your-random-api-token-here

# =============================================================================
# OPTIONAL - Paths and Configuration
# =============================================================================

# Custom save file path (optional, auto-detected if not set)
# STELLARIS_SAVE_PATH=/path/to/your/save.sav

# SQLite database path for history tracking (optional)
# Default: ~/.stellaris-companion/history.db
# STELLARIS_DB_PATH=/path/to/history.db

# Custom Rust parser binary location (optional, auto-detected if not set)
# PARSER_BINARY=/path/to/stellaris-parser

# =============================================================================
# OPTIONAL - Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# STELLARIS_LOG_LEVEL=INFO

# Directory for log files (optional, logs to console only if not set)
# STELLARIS_LOG_DIR=/path/to/logs
